# Dépendances installées localement — reconstruites dans l'image via npm ci
node_modules/

# Logs applicatifs — inutiles dans l'image, peuvent contenir des données sensibles
*.log
npm-debug.log*

# Fichiers d'environnement — contiennent des secrets, jamais dans une image Docker
.env
.env.*

# Fichiers Git — historique de code inutile dans le conteneur
.git/
.gitignore

# Répertoire de tests — non nécessaire dans l'image de production (stage 2)
test/

# Dockerfile lui-même — inutile dans le conteneur
Dockerfile
.dockerignore

# Répertoires de build locaux
dist/
coverage/
